# Class: <http://purl.obolibrary.org/obo/DRON_00000031> (drug administration)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000111> <http://purl.obolibrary.org/obo/DRON_00000031> "administration of a drug product to an organism"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/DRON_00000031> "A treatment that has as participants an extended organism and a drug product and that results in part of the drug product being located in the extended organism."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/DRON_00000031> "William R. Hogan"@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/DRON_00000031> <http://purl.obolibrary.org/obo/dron.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/DRON_00000031> "drug administration"@en)
SubClassOf(<http://purl.obolibrary.org/obo/DRON_00000031> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/OGMS_0000090> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000057> <http://purl.obolibrary.org/obo/COB_0000022>) ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000057> <http://purl.obolibrary.org/obo/DRON_00000005>)))

# Class: <http://purl.obolibrary.org/obo/DRON_00000074> (drug product)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/DRON_00000074> "A material entity that (1) contains at least one scattered molecular aggregate as part and (2) is intended, when administered to an organism, to produce some therapeutic and/or psychoactive effect."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/DRON_00000074> "William R. Hogan"@en)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/DRON_00000074> <https://orcid.org/0000-0001-6378-1703>)
AnnotationAssertion(<http://purl.org/dc/terms/contributor> <http://purl.obolibrary.org/obo/DRON_00000074> <https://orcid.org/0000-0002-5039-2052>)
AnnotationAssertion(<http://purl.org/dc/terms/creator> <http://purl.obolibrary.org/obo/DRON_00000074> "http://orcid.org/0000-0002-9881-1017")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/DRON_00000074> "The \"intention\" part is important because of situations, such as that with phenylephrine, where it was not effective for the labeled use. Even when a drug is proven effective for a particular indication, it might not be therapeutic for every indivdiual to whom it is administered."@en)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/DRON_00000074> "The psychoactive effect is added for illicit drugs such as crack cocaine."@en)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/DRON_00000074> "We are including prophylactic and diagnostic effects / usage under the more general heading of 'therapeutic'."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/DRON_00000074> <http://purl.obolibrary.org/obo/dron.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/DRON_00000074> "drug product"@en)
EquivalentClasses(<http://purl.obolibrary.org/obo/DRON_00000074> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/BFO_0000040> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000051> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/OBI_0000576> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000053> <http://purl.obolibrary.org/obo/DRON_00000028>)))))
SubClassOf(<http://purl.obolibrary.org/obo/DRON_00000074> <http://purl.obolibrary.org/obo/BFO_0000040>)
SubClassOf(<http://purl.obolibrary.org/obo/DRON_00000074> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000051> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/OBI_0000576> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000053> <http://purl.obolibrary.org/obo/DRON_00000028>))))

# Class: <http://purl.obolibrary.org/obo/GO_0003674> (molecular_function)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "GOC:pdt") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GO_0003674> "A molecular process that can be carried out by the action of a single macromolecular machine, usually via direct physical interactions with other molecular entities. Function in this sense denotes an action, or activity, that a gene product (or a complex) performs.")
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <http://purl.obolibrary.org/obo/GO_0003674> "This is the same as GO molecular function"@en)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/GO_0003674> "molecular function")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/GO_0003674> "GO:0003674")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/GO_0003674> "Note that, in addition to forming the root of the molecular function ontology, this term is recommended for the annotation of gene products whose molecular function is unknown. When this term is used for annotation, it indicates that no information was available about the molecular function of the gene product annotated as of the date the annotation was made; the evidence code 'no data' (ND), is used to indicate this. Despite its name, this is not a type of 'function' in the sense typically defined by upper ontologies such as Basic Formal Ontology (BFO). It is instead a BFO:process carried out by a single gene product or complex.")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/GO_0003674> <http://purl.obolibrary.org/obo/go.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GO_0003674> "gene product or complex activity"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GO_0003674> "molecular_function")
SubClassOf(<http://purl.obolibrary.org/obo/GO_0003674> <http://purl.obolibrary.org/obo/BFO_0000015>)

# Class: <http://purl.obolibrary.org/obo/GO_0016301> (kinase activity)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "ISBN:0198506732") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/GO_0016301> "Catalysis of the transfer of a phosphate group, usually from ATP, to a substrate molecule.")
AnnotationAssertion(Annotation(rdfs:label "FN3KRP phosphorylates PsiAm, RibAm") <http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GO_0016301> "Reactome:R-HSA-6788855")
AnnotationAssertion(Annotation(rdfs:label "FN3K phosphorylates ketosamines") <http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/GO_0016301> "Reactome:R-HSA-6788867")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/GO_0016301> "phosphokinase activity")
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#id> <http://purl.obolibrary.org/obo/GO_0016301> "GO:0016301")
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/GO_0016301> "Note that this term encompasses all activities that transfer a single phosphate group; although ATP is by far the most common phosphate donor, reactions using other phosphate donors are included in this term.")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/GO_0016301> <http://purl.obolibrary.org/obo/go.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/GO_0016301> "kinase activity")
SubClassOf(<http://purl.obolibrary.org/obo/GO_0016301> <http://purl.obolibrary.org/obo/GO_0003674>)
