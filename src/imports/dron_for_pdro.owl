# Class: <http://purl.obolibrary.org/obo/DRON_00000001> (clinical drug role)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/DRON_00000001> "A role of a material entity to prevent, diagnose, treat, or study disease and/or its effects."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/DRON_00000001> "William Hogan")
AnnotationAssertion(<http://purl.org/dc/terms/creator> <http://purl.obolibrary.org/obo/DRON_00000001> "William Hogan")
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/DRON_00000001> <http://purl.obolibrary.org/obo/dron.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/DRON_00000001> "clinical drug role"@en)
SubClassOf(<http://purl.obolibrary.org/obo/DRON_00000001> <http://purl.obolibrary.org/obo/BFO_0000023>)

# Class: <http://purl.obolibrary.org/obo/DRON_00000005> (clinical drug product)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/DRON_00000005> "A drug product that is bearer of a clinical drug role."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/DRON_00000005> "William Hogan"@en)
AnnotationAssertion(<http://purl.org/dc/terms/creator> <http://purl.obolibrary.org/obo/DRON_00000005> "https://orcid.org/0000-0002-9881-1017"^^xsd:anyURI)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/DRON_00000005> "We changed the label to 'clinical drug product' because it was clear that the part of the definition re: bearer of a \"clinical drug role\" made it such. Other drugs don't have clinical drug roles, especially illicit ones. Therefore we changed the label here, as well as the subClassOf. Now it is subClassOf \"drug product\", which also required changing the definition here."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/DRON_00000005> <http://purl.obolibrary.org/obo/dron.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/DRON_00000005> "clinical drug product"@en)
