SubClassOf(<http://purl.obolibrary.org/obo/DRON_00000005> <http://purl.obolibrary.org/obo/DRON_00000074>)
SubClassOf(<http://purl.obolibrary.org/obo/DRON_00000005> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/RO_0000053> <http://purl.obolibrary.org/obo/DRON_00000001>))

# Class: <http://purl.obolibrary.org/obo/DRON_00000028> (active ingredient)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000111> <http://purl.obolibrary.org/obo/DRON_00000028> "active ingredient role"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/DRON_00000028> "A role of a scattered molecular aggregate that is part of a drug product that is realized by (1) administration of the drug to an organism followed by (2) some change in the structure or functioning of some part of the organism."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/DRON_00000028> "William R. Hogan"@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/DRON_00000028> <http://purl.obolibrary.org/obo/dron.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/DRON_00000028> "active ingredient"@en)
SubClassOf(<http://purl.obolibrary.org/obo/DRON_00000028> <http://purl.obolibrary.org/obo/DRON_00000030>)

# Class: <http://purl.obolibrary.org/obo/DRON_00000029> (excipient)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000111> <http://purl.obolibrary.org/obo/DRON_00000029> "excipient role"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/DRON_00000029> "A role of a scattered molecular aggregate in aiding the manufacture, prolonging the shelf life, or ensuring proper administration of a drug product."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/DRON_00000029> "William R. Hogan"@en)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/DRON_00000029> "not all excipients aid in delivery of the drug, although it is their most common role.  examples include preservatives and sorbents."@en)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/DRON_00000029> "some excipients are used in manufacture of a drug product and do not end up being part of the drug product at the end, for example, water in the manufacture of lyophilized products and inert gasses in the headspace of containers (http://www.ipapharma.org/epharmatimes/Mar2013/#65).

the net result is that the aggregate bearing the excipient role need not be part of the drug product."@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/DRON_00000029> <http://purl.obolibrary.org/obo/dron.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/DRON_00000029> "excipient"@en)
SubClassOf(<http://purl.obolibrary.org/obo/DRON_00000029> <http://purl.obolibrary.org/obo/DRON_00000030>)

# Class: <http://purl.obolibrary.org/obo/DRON_00000030> (role of scattered molecular aggregate)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000111> <http://purl.obolibrary.org/obo/DRON_00000030> "role of a scattered molecular aggregate"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/DRON_00000030> "A role borne by a scattered molecular aggregate and realized by its grains participating in one or more processes."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/DRON_00000030> "William R. Hogan"@en)
AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/DRON_00000030> <http://purl.obolibrary.org/obo/dron.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/DRON_00000030> "role of scattered molecular aggregate"@en)
