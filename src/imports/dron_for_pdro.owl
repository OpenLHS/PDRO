AnnotationAssertion(rdfs:isDefinedBy <http://purl.obolibrary.org/obo/RO_0000053> <http://purl.obolibrary.org/obo/ro.owl>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/RO_0000053> "has characteristic"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/RO_0000053> "is bearer of"@en)
